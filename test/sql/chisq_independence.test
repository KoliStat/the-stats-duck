# name: test/sql/chisq_independence.test
# description: Chi-square test of independence
# group: [stats_duck]

require stats_duck

# 2x2 with clear association: rows tied to cols.
# Counts: (1,1)=8, (1,2)=2, (2,1)=2, (2,2)=8 → expected 5 each
# χ² = 4 * (8-5)² / 5 = 7.2; df = 1; R: p ≈ 0.0073
statement ok
CREATE TABLE associated AS
SELECT '1' AS r, '1' AS c FROM range(8) UNION ALL
SELECT '1',     '2' FROM range(2) UNION ALL
SELECT '2',     '1' FROM range(2) UNION ALL
SELECT '2',     '2' FROM range(8);

query TTTT
SELECT (s.r).test_type,
       ROUND((s.r).chi_square, 4),
       (s.r).df,
       ROUND((s.r).p_value, 4)
FROM (SELECT chisq_independence(r, c) AS r FROM associated) AS s
----
Chi-square Independence	7.2	1.0	0.0073

# Verify n is row count (total observations, not cell count)
query T
SELECT (s.r).n FROM (SELECT chisq_independence(r, c) AS r FROM associated) AS s
----
20

# Independent table: counts matching expected → χ² close to zero
# (1,1)=10, (1,2)=10, (2,1)=10, (2,2)=10 → all expected = 10 → χ² = 0
statement ok
CREATE TABLE independent AS
SELECT '1' AS r, '1' AS c FROM range(10) UNION ALL
SELECT '1',     '2' FROM range(10) UNION ALL
SELECT '2',     '1' FROM range(10) UNION ALL
SELECT '2',     '2' FROM range(10);

query TT
SELECT ROUND((s.r).chi_square, 4),
       (s.r).p_value > 0.99
FROM (SELECT chisq_independence(r, c) AS r FROM independent) AS s
----
0.0	true

# 3x3 (df = (3-1)(3-1) = 4)
statement ok
CREATE TABLE three_by_three AS
SELECT '1' AS r, '1' AS c FROM range(20) UNION ALL
SELECT '1',     '2' FROM range(15) UNION ALL
SELECT '1',     '3' FROM range(10) UNION ALL
SELECT '2',     '1' FROM range(12) UNION ALL
SELECT '2',     '2' FROM range(18) UNION ALL
SELECT '2',     '3' FROM range(14) UNION ALL
SELECT '3',     '1' FROM range(8)  UNION ALL
SELECT '3',     '2' FROM range(17) UNION ALL
SELECT '3',     '3' FROM range(16);

# R: chisq.test → χ²=7.063, df=4, p=0.133
query TTTT
SELECT (s.r).df,
       ROUND((s.r).chi_square, 3),
       ROUND((s.r).p_value, 3),
       (s.r).n
FROM (SELECT chisq_independence(r, c) AS r FROM three_by_three) AS s
----
4.0	7.063	0.133	130

# NULLs are skipped
statement ok
INSERT INTO associated VALUES (NULL, '1'), ('1', NULL);

query T
SELECT (s.r).n FROM (SELECT chisq_independence(r, c) AS r FROM associated) AS s
----
20

# Too few observations: degenerate (single cell) → NULL
query T
SELECT chisq_independence(r, c)
FROM (VALUES ('1','1'), ('1','1')) AS t(r, c)
----
NULL

# GROUP BY: separate test per group
statement ok
CREATE TABLE per_group AS
SELECT 's1' AS g, '1' AS r, '1' AS c FROM range(8) UNION ALL
SELECT 's1', '1', '2' FROM range(2) UNION ALL
SELECT 's1', '2', '1' FROM range(2) UNION ALL
SELECT 's1', '2', '2' FROM range(8) UNION ALL
SELECT 's2', '1', '1' FROM range(5) UNION ALL
SELECT 's2', '1', '2' FROM range(5) UNION ALL
SELECT 's2', '2', '1' FROM range(5) UNION ALL
SELECT 's2', '2', '2' FROM range(5);

query TT
SELECT g, (chisq_independence(r, c)).p_value < 0.05
FROM per_group GROUP BY g ORDER BY g
----
s1	true
s2	false
